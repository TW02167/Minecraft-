<!DOCTYPE html>

<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport"/>
<title>VoxelCraft: Pocket Edition</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&amp;family=JetBrains+Mono:wght@400;700&amp;display=swap" rel="stylesheet"/>
<style>
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: #0b1d33;
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            user-select: none;
            -webkit-user-select: none;
            touch-action: none;
        }

        #game-container {
            position: relative;
            width: 100%;
            height: 100%;
        }

        canvas {
            display: block;
            width: 100%;
            height: 100%;
        }

        /* PE Crosshair - Match IMG_1562.jpeg */
        #crosshair {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 16px;
            height: 16px;
            transform: translate(-50%, -50%);
            pointer-events: none;
            z-index: 10;
        }
        #crosshair::before, #crosshair::after {
            content: '';
            position: absolute;
            background: rgba(255, 255, 255, 0.75);
        }
        #crosshair::before { top: 0; left: 7px; width: 2px; height: 16px; }
        #crosshair::after { top: 7px; left: 0; width: 16px; height: 2px; }

        .dpad-container {
            position: absolute;
            bottom: 30px;
            left: 30px;
            width: 135px;
            height: 135px;
            z-index: 30;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            grid-template-rows: repeat(3, 1fr);
            gap: 1px;
        }

        .dpad-btn {
            background: rgba(45, 45, 45, 0.65);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 8px;
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            user-select: none;
            -webkit-user-select: none;
            box-shadow: 0 4px 6px rgba(0,0,0,0.4);
            transition: background 0.1s;
        }

        .dpad-btn:active, .dpad-btn.active {
            background: rgba(255, 255, 255, 0.35);
            border-color: rgba(255, 255, 255, 0.6);
        }

        .dpad-up { grid-column: 2; grid-row: 1; }
        .dpad-left { grid-column: 1; grid-row: 2; }
        .dpad-center { grid-column: 2; grid-row: 2; border-radius: 50%; background: rgba(30, 30, 30, 0.85); font-size: 11px; }
        .dpad-right { grid-column: 3; grid-row: 2; }
        .dpad-down { grid-column: 2; grid-row: 3; }

        .actions-container {
            position: absolute;
            bottom: 30px;
            right: 30px;
            width: 130px;
            height: 130px;
            z-index: 30;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: repeat(2, 1fr);
            gap: 12px;
        }

        .action-btn {
            background: rgba(45, 45, 45, 0.65);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            color: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 6px rgba(0,0,0,0.4);
            transition: background 0.1s, transform 0.05s;
        }

        .action-btn:active {
            background: rgba(255, 255, 255, 0.35);
            transform: scale(0.95);
        }

        .mc-btn {
            background-color: #8c8c8c;
            border: 4px solid;
            border-top-color: #dbdbdb;
            border-left-color: #dbdbdb;
            border-right-color: #555555;
            border-bottom-color: #555555;
            color: #ffffff;
            text-shadow: 2px 2px 0px #3f3f3f;
            font-weight: bold;
            font-family: monospace;
            box-shadow: 0 4px 0px #000000;
            text-align: center;
        }

        .mc-btn:active {
            border-top-color: #555555;
            border-left-color: #555555;
            border-right-color: #dbdbdb;
            border-bottom-color: #dbdbdb;
            transform: translateY(2px);
            box-shadow: 0 2px 0px #000000;
        }

        .tab-btn-active {
            background-color: #5c5c5c !important;
            border-top-color: #8c8c8c !important;
            border-left-color: #8c8c8c !important;
            border-right-color: #2c2c2c !important;
            border-bottom-color: #2c2c2c !important;
        }

        .pixel-font { font-family: 'Press Start 2P', monospace; }
        .menu-mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }

        .heart-bar {
            display: flex;
            gap: 3px;
            font-size: 16px;
        }

        #menu-canvas-container {
            position: absolute;
            inset: 0;
            z-index: 1;
            pointer-events: none;
        }

        .inv-scrollbar::-webkit-scrollbar { width: 6px; }
        .inv-scrollbar::-webkit-scrollbar-track { background: rgba(0,0,0,0.1); }
        .inv-scrollbar::-webkit-scrollbar-thumb { background: #888; border-radius: 3px; }
    </style>
</head>
<body class="bg-slate-950 select-none overflow-hidden">
<div class="relative w-full h-full" id="game-container">
<!-- Main Game 3D Engine Canvas -->
