        function buildParkourLevel() {
            blocksWorld.clear(); clearAllChunks();
            const spawnZ = 0;
            for (let x = -2; x <= 2; x++) for (let z = -2; z <= 2; z++) blocksWorld.set(`${x},22,${z}`, 27);
            blocksWorld.set(`0,23,0`, 21);
            
            let cur = new THREE.Vector3(0, 22, 2);
            for (let i = 0; i < 25; i++) {
                const type = Math.random() > 0.8 ? (Math.random() > 0.5 ? 23 : 24) : 27;
                cur.z += 3 + Math.floor(Math.random()*2);
                cur.x += Math.floor(Math.random()*3) - 1;
                cur.y += Math.floor(Math.random()*2) - 0.5;
                blocksWorld.set(`${Math.floor(cur.x)},${Math.floor(cur.y)},${Math.floor(cur.z)}`, type);
                if (i % 8 === 7) blocksWorld.set(`${Math.floor(cur.x)},${Math.floor(cur.y)+1},${Math.floor(cur.z)}`, 21);
            }
            blocksWorld.set(`${Math.floor(cur.x)},${Math.floor(cur.y)},${Math.floor(cur.z+4)}`, 25);
            player.pos.set(0, 24, 0); parkourCheckpoint.set(0, 24, 0);
            parkourTimerStart = performance.now(); isParkourRunning = true;
        }

