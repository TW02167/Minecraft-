        function updatePlayerPhysics(dt, char) {
            if (char.isDead) return;
            const inWater = getBlockAt(char.pos.x, char.pos.y, char.pos.z) === 8;
            const standingOn = getBlockAt(char.pos.x, char.pos.y - 0.1, char.pos.z);
            
            let speedMult = 1.0;
            if (standingOn === 24) speedMult = 2.5;
            if (char.isSneaking) speedMult *= 0.4;
            
            if (!char.isFlying) char.vel.y -= (inWater ? 8 : CONFIG.gravity) * dt;
            else char.vel.y = 0;

            if (char === player) {
                const move = new THREE.Vector3();
                const f = new THREE.Vector3(-Math.sin(char.rot.yaw), 0, -Math.cos(char.rot.yaw));
                const r = new THREE.Vector3(Math.cos(char.rot.yaw), 0, -Math.sin(char.rot.yaw));
                if (inputs.forward) move.add(f); if (inputs.backward) move.sub(f);
                if (inputs.left) move.sub(r); if (inputs.right) move.add(r);
                move.normalize();
                char.vel.x = move.x * CONFIG.moveSpeed * speedMult * (inWater ? 0.5 : 1);
                char.vel.z = move.z * CONFIG.moveSpeed * speedMult * (inWater ? 0.5 : 1);
                if (char.isFlying) {
                    if (inputs.jump) char.vel.y = CONFIG.jumpForce;
                    else if (inputs.sneak) char.vel.y = -CONFIG.jumpForce;
                } else if (inputs.jump && char.onGround) {
                    char.vel.y = standingOn === 23 ? 15 : CONFIG.jumpForce;
                    char.onGround = false; sfx.playJump();
                }
            }

            char.pos.x += char.vel.x * dt; if (checkCollision(char)) char.pos.x -= char.vel.x * dt;
            char.pos.z += char.vel.z * dt; if (checkCollision(char)) char.pos.z -= char.vel.z * dt;
            char.pos.y += char.vel.y * dt; char.onGround = false;
            if (checkCollision(char)) {
                if (char.vel.y < 0) { char.pos.y = Math.ceil(char.pos.y); char.onGround = true; }
                else char.pos.y = Math.floor(char.pos.y) - 0.01;
                char.vel.y = 0;
            }

            if (standingOn === 21 && activeGameMode === 'parkour') {
                if (parkourCheckpoint.distanceTo(char.pos) > 1) {
                    parkourCheckpoint.copy(char.pos); showToast("Checkpoint Set! 🚩", "success"); sfx.playPlace();
                }
            }
            if (standingOn === 25 && (activeGameMode === 'parkour' || activeGameMode === 'team_obby')) {
                if (activeGameMode === 'parkour' && isParkourRunning) {
                    const time = (performance.now() - parkourTimerStart) / 1000;
                    if (time < sessionBestParkour) { sessionBestParkour = time; document.getElementById('parkour-best').innerText = `BEST: ${time.toFixed(1)}s`; }
                    isParkourRunning = false; sfx.playWin(); document.getElementById('victory-screen').classList.remove('hidden');
                }
            }
            if (char.pos.y < -10) { 
                if (activeGameMode === 'parkour') { char.pos.copy(parkourCheckpoint); char.vel.set(0,0,0); }
                else if (activeGameMode === 'team_obby') { char.pos.set(0,24,0); char.vel.set(0,0,0); }
                else triggerPlayerDeath();
            }
            if (char.mesh) { char.mesh.position.copy(char.pos); char.mesh.rotation.y = char.rot.yaw; char.mesh.visible = (char !== player); }
        }

        function checkCollision(char) {
            const b = { min: char.pos.clone().subScalar(char.radius), max: char.pos.clone().addScalar(char.radius) };
            b.max.y += char.height;
            for (let x = Math.floor(b.min.x); x <= Math.floor(b.max.x); x++) {
                for (let y = Math.floor(b.min.y); y <= Math.floor(b.max.y); y++) {
                    for (let z = Math.floor(b.min.z); z <= Math.floor(b.max.z); z++) {
                        const id = getBlockAt(x, y, z);
                        if (id !== 0 && id !== 8) return true;
                    }
                }
            }
            return false;
        }

        function triggerPlayerDeath() { player.isDead = true; document.getElementById('death-screen').classList.remove('hidden'); document.exitPointerLock(); }

        function performRaycast() {
            const start = player.pos.clone(); start.y += player.height * 0.45;
            const dir = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);
            for (let d = 0; d < 5; d += 0.1) {
                const p = start.clone().addScaledVector(dir, d);
                const bx = Math.floor(p.x); const by = Math.floor(p.y); const bz = Math.floor(p.z);
                const id = getBlockAt(bx, by, bz);
                if (id !== 0 && id !== 8) return { x: bx, y: by, z: bz, n: dir.clone().negate().round(), key: `${bx},${by},${bz}` };
            }
            return null;
        }

        function triggerPlaceAction() {
            const hit = performRaycast();
            if (hit) {
                const px = hit.x + hit.n.x; const py = hit.y + hit.n.y; const pz = hit.z + hit.n.z;
                const active = hotbarSelection[activeHotbarIndex];
                if (active) {
                    setBlockAt(px, py, pz, active);
                    if (isBrushEnabled) {
                        for (let i = 1; i < 3; i++) setBlockAt(px + hit.n.x*i, py + hit.n.y*i, pz + hit.n.z*i, active);
                    }
                    triggerSwing();
                }
            }
        }

