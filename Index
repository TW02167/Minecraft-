        document.getElementById('mode-classic-btn').onclick = () => { activeGameMode = 'classic'; document.querySelectorAll('#panel-worlds .mc-btn').forEach(b => b.classList.remove('tab-btn-active')); document.getElementById('mode-classic-btn').classList.add('tab-btn-active'); };
        document.getElementById('mode-parkour-btn').onclick = () => { activeGameMode = 'parkour'; document.querySelectorAll('#panel-worlds .mc-btn').forEach(b => b.classList.remove('tab-btn-active')); document.getElementById('mode-parkour-btn').classList.add('tab-btn-active'); };
        document.getElementById('tab-worlds-btn').onclick = () => { document.getElementById('panel-worlds').classList.remove('hidden'); document.getElementById('panel-friends').classList.add('hidden'); document.getElementById('tab-worlds-btn').classList.add('tab-btn-active'); document.getElementById('tab-friends-btn').classList.remove('tab-btn-active'); };
        document.getElementById('tab-friends-btn').onclick = () => { document.getElementById('panel-friends').classList.remove('hidden'); document.getElementById('panel-worlds').classList.add('hidden'); document.getElementById('tab-friends-btn').classList.add('tab-btn-active'); document.getElementById('tab-worlds-btn').classList.remove('tab-btn-active'); };

        window.onkeydown = e => {
            const k = e.key.toLowerCase();
            if (k === 'w') inputs.forward = true; if (k === 's') inputs.backward = true; if (k === 'a') inputs.left = true; if (k === 'd') inputs.right = true;
            if (e.code === 'Space') inputs.jump = true; if (e.shiftKey) inputs.sneak = true;
            if (k === 'e') toggleInventoryModal();
            const n = parseInt(k); if (n >= 1 && n <= 9) { activeHotbarIndex = n - 1; buildHotbarHTML(); }
        };
        window.onkeyup = e => {
            const k = e.key.toLowerCase();
            if (k === 'w') inputs.forward = false; if (k === 's') inputs.backward = false; if (k === 'a') inputs.left = false; if (k === 'd') inputs.right = false;
            if (e.code === 'Space') inputs.jump = false; if (!e.shiftKey) inputs.sneak = false;
        };
        window.onmousedown = e => { if (document.pointerLockElement === canvasEl) { if (e.button === 0) { if (e.shiftKey && isBrushEnabled) triggerPlaceAction(); else { activeMiningKey = null; miningProgress = 0; } } else if (e.button === 2) triggerPlaceAction(); } };
        window.onmousemove = e => { if (document.pointerLockElement === canvasEl) { player.rot.yaw -= e.movementX * 0.003; player.rot.pitch = Math.max(-Math.PI/2.1, Math.min(Math.PI/2.1, player.rot.pitch - e.movementY * 0.003)); } };

        let lastFrame = performance.now();
        function animate() {
            requestAnimationFrame(animate);
            const now = performance.now(); const dt = Math.min((now - lastFrame)/1000, 0.1); lastFrame = now;
            if (!document.getElementById('gameCanvas').classList.contains('hidden')) {
                updatePlayerPhysics(dt, pSteve); updateActiveChunksAroundPlayer();
                if (isSwingAnimating) { swingProgress += dt * 15; if (swingProgress >= Math.PI) { isSwingAnimating = false; playerArmMesh.rotation.z = 0; } else playerArmMesh.rotation.z = -Math.sin(swingProgress) * 0.6; }
                const hit = performRaycast(); if (hit) { outlineBox.visible = true; outlineBox.position.set(hit.x+0.5, hit.y+0.5, hit.z+0.5); } else outlineBox.visible = false;
                camera.position.copy(player.pos); camera.position.y += player.isSneaking ? 1.2 : 1.6;
                camera.rotation.set(player.rot.pitch, player.rot.yaw, 0, 'YXZ');
                renderer.render(scene, camera);
                if (activeGameMode === 'parkour' && isParkourRunning) { const t = (performance.now()-parkourTimerStart)/1000; document.getElementById('parkour-timer').innerText = `TIME: ${t.toFixed(1)}s`; }
            }
        }

        window.onload = () => { initFirebase(); buildHotbarHTML(); animate(); if (isTouchDevice()) document.getElementById('mobile-hud').classList.remove('hidden'); };
        window.onresize = () => { camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight); };
    </script>
</body></html>
