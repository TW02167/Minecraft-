        function getLandscapeHeightAndBiome(x, z) {
            if (selectedMapPreset === 'void') return { height: -1, biome: 'void' };
            if (selectedMapPreset === 'flat') return { height: 8, biome: 'flat' };
            const nx = x * 0.0035; const nz = z * 0.0035;
            const biomeNoise = noise2D(nx, nz);
            let biome = "plains", heightOffset = 0, baseHeight = 15;
            if (biomeNoise < 0.3) { biome = "desert"; baseHeight = 14; }
            else if (biomeNoise > 0.8) { biome = "mountains"; baseHeight = 16; heightOffset = noise2D(x*0.02, z*0.02)*12; }
            return { height: Math.floor(baseHeight + heightOffset), biome };
        }

        function getBlockAt(x, y, z) {
            const rx = Math.floor(x); const ry = Math.floor(y); const rz = Math.floor(z);
            if (ry < 0 || ry >= CHUNK_HEIGHT) return 0;
            const key = `${rx},${ry},${rz}`;
            if (blocksWorld.has(key)) return blocksWorld.get(key);
            if (activeGameMode === "parkour" || activeGameMode === "team_obby") return 0;
            const land = getLandscapeHeightAndBiomeCached(rx, rz);
            if (land.height === -1) return 0;
            if (ry === 0) return 26;
            if (ry < land.height - 3) return 3;
            if (ry < land.height) return land.biome === 'desert' ? 20 : 2;
            if (ry === land.height) return land.biome === 'desert' ? 9 : 1;
            if (ry <= CONFIG.waterLevel) return 8;
            return 0;
        }

        function rebuildChunk(cx, cz) {
            const ckey = `${cx},${cz}`;
            let groupMeshes = chunkMeshGroups.get(ckey) || new Map();
            chunkMeshGroups.set(ckey, groupMeshes);
            const buffers = new Map();
            const startX = cx * CHUNK_SIZE; const startZ = cz * CHUNK_SIZE;
            for (let lx = 0; lx < CHUNK_SIZE; lx++) {
                for (let lz = 0; lz < CHUNK_SIZE; lz++) {
                    for (let y = 0; y < CHUNK_HEIGHT; y++) {
                        const x = startX + lx; const z = startZ + lz;
                        const blockId = getBlockAt(x, y, z);
                        if (blockId === 0) continue;
                        for (const face of FACES) {
                            const nb = getBlockAt(x+face.normal[0], y+face.normal[1], z+face.normal[2]);
                            if (nb !== 0 && !BLOCK_TYPES[nb].isTransparent) continue;
                            const groupKey = `${blockId}_${blockId === 1 ? (face.name === 'py' ? 'top' : (face.name === 'ny' ? 'bottom' : 'side')) : 'side'}`;
                            let b = buffers.get(groupKey) || { pos: [], norm: [], uvs: [], idx: [], count: 0 };
                            buffers.set(groupKey, b);
                            const startIdx = b.count;
                            face.corners.forEach(c => b.pos.push(x + c[0], y + c[1], z + c[2]));
                            face.corners.forEach(() => b.norm.push(...face.normal));
                            b.uvs.push(0,0, 1,0, 1,1, 0,1);
                            b.idx.push(startIdx, startIdx+1, startIdx+2, startIdx, startIdx+2, startIdx+3);
                            b.count += 4;
                        }
                    }
                }
            }
            groupMeshes.forEach((mesh, k) => { if (!buffers.has(k)) { scene.remove(mesh); mesh.geometry.dispose(); groupMeshes.delete(k); }});
            buffers.forEach((b, k) => {
                const geo = new THREE.BufferGeometry();
                geo.setAttribute('position', new THREE.Float32BufferAttribute(b.pos, 3));
                geo.setAttribute('normal', new THREE.Float32BufferAttribute(b.norm, 3));
                geo.setAttribute('uv', new THREE.Float32BufferAttribute(b.uvs, 2));
                geo.setIndex(b.idx);
                let mesh = groupMeshes.get(k);
                if (mesh) { mesh.geometry.dispose(); mesh.geometry = geo; }
                else { mesh = new THREE.Mesh(geo, getChunkMaterial(k)); scene.add(mesh); groupMeshes.set(k, mesh); }
            });
        }

        function updateActiveChunksAroundPlayer() {
            const pcx = Math.floor(player.pos.x / CHUNK_SIZE); const pcz = Math.floor(player.pos.z / CHUNK_SIZE);
            const targets = new Set();
            for (let dx = -RENDER_DIST; dx <= RENDER_DIST; dx++) {
                for (let dz = -RENDER_DIST; dz <= RENDER_DIST; dz++) targets.add(`${pcx+dx},${pcz+dz}`);
            }
            activeLoadedChunks.forEach(k => { if (!targets.has(k)) { 
                const ms = chunkMeshGroups.get(k); if (ms) ms.forEach(m => { scene.remove(m); m.geometry.dispose(); }); 
                chunkMeshGroups.delete(k); activeLoadedChunks.delete(k);
            }});
            targets.forEach(k => { if (!activeLoadedChunks.has(k)) {
                const [x, z] = k.split(',').map(Number); rebuildChunk(x, z); activeLoadedChunks.add(k);
            }});
        }

