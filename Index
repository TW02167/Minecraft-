<div class="absolute inset-0" id="character-canvas-box"></div>
<button class="absolute bottom-3 right-3 w-11 h-11 rounded-lg bg-neutral-800/80 hover:bg-neutral-700 border-2 border-neutral-600 flex items-center justify-center text-xl shadow-lg active:scale-90 transition pointer-events-auto" id="btn-skin-selector" title="Change Skin">
